# Environment template — copy for local development:
#   cp .env.example .env.local
#
# Prisma CLI loads .env.local from the repo root via scripts/prisma-cli.cjs.
# Schema lives at prisma/schema.prisma (shared by all services).

NODE_ENV=local

# Database (docker-compose.dev.yml — host port 5433 to avoid system PostgreSQL on 5432)
DATABASE_URL=postgresql://rev_user:rev_password@localhost:5433/rev_db
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=rev_user
DB_PASSWORD=rev_password
DB_NAME=rev_db

# Redis (docker-compose.dev.yml — host port 6380)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6380
REDIS_TLS=false

# RabbitMQ (docker-compose.dev.yml — AMQP 5673; management UI http://localhost:15673, user/pass kritly/kritly)
RABBITMQ_URL=amqp://kritly:kritly@localhost:5673
RABBITMQ_NOTIFICATION_QUEUE=notification-service.send

# SMTP
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Kritly <noreply@kritly.com>
SMTP_SECURE=false

# Notification template defaults (override NOTIFICATION_APP_URL locally, e.g. http://localhost:3000)
NOTIFICATION_APP_URL=https://kritly.com
NOTIFICATION_SUPPORT_EMAIL=support@kritly.com
NOTIFICATION_TEMPLATE_CACHE_TTL=1800

# JWT (required for development/staging/production)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=15m

# Service ports
PORT=3000
AUTH_SERVICE_HOST=localhost
AUTH_SERVICE_PORT=3001
UPLOAD_SERVICE_HOST=localhost
UPLOAD_SERVICE_PORT=3002
NOTIFICATION_SERVICE_HOST=localhost
NOTIFICATION_SERVICE_GRPC_PORT=3003
GRPC_USE_TLS=false

# OTP / verification
OTP_TTL_SECONDS=600
OTP_MAX_VERIFY_ATTEMPTS=5
OTP_SEND_RATE_LIMIT=3
VERIFICATION_TOKEN_TTL_SECONDS=600

# Object storage (S3-compatible — Cloudflare R2, AWS S3, MinIO)
S3_BUCKET=kritly-uploads
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL_BASE=
UPLOAD_PRESIGNED_URL_TTL=900

# Social auth (optional for local dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/oauth/google/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/oauth/facebook/callback

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_PRIVATE_KEY=
APPLE_CLIENT_SECRET=
APPLE_CALLBACK_URL=http://localhost:3000/api/auth/oauth/apple/callback

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_CALLBACK_URL=http://localhost:3000/api/auth/oauth/instagram/callback

# Public gateway URL used to build OAuth callback URLs
GATEWAY_PUBLIC_URL=http://localhost:3000
# Frontend URL to receive OAuth tokens (returned in URL hash fragment)
OAUTH_SUCCESS_REDIRECT_URL=http://localhost:3000/auth/callback
# Optional secret for signing OAuth state (defaults to JWT_SECRET)
OAUTH_STATE_SECRET=
