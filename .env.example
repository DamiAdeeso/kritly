# Copy to `.env` for local development:
#   cp .env.example .env
#
# Only `.env` is loaded. For `NODE_ENV=local`, unset keys get defaults from
# `config/load-root-env.cjs` (docker-compose.dev.yml host ports).
# Staging/production: set NODE_ENV and all secrets in `.env` or your platform.

NODE_ENV=local

# Secrets — set in .env (required when NODE_ENV is not local)
JWT_SECRET=change-me-to-a-long-random-string

# Database (override if not using local defaults)
# DATABASE_URL=postgresql://rev_user:rev_password@localhost:5433/rev_db

# Redis
# REDIS_URL=redis://localhost:6380

# RabbitMQ
# RABBITMQ_URL=amqp://kritly:kritly@localhost:5673

# SMTP (Mailtrap / provider)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Kritly <noreply@kritly.com>

# Notification templates
NOTIFICATION_SUPPORT_EMAIL=support@kritly.com
NOTIFICATION_TEMPLATE_CACHE_TTL=1800

# Object storage (S3-compatible)
S3_BUCKET=kritly-uploads
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL_BASE=

# Social auth (optional for local dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/oauth/google/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/oauth/facebook/callback

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_PRIVATE_KEY=
APPLE_CLIENT_SECRET=
APPLE_CALLBACK_URL=http://localhost:3000/api/auth/oauth/apple/callback

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_CALLBACK_URL=http://localhost:3000/api/auth/oauth/instagram/callback

OAUTH_STATE_SECRET=
