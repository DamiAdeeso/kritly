{
  "name": "kritly",
  "version": "1.0.0",
  "description": "Kritly microservices platform",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "build": "nx build",
    "test": "nx test",
    "lint": "nx lint",
    "dev": "cross-env NODE_ENV=local nx run-many --target=serve --projects=gateway,auth-service,notification-service,upload-service --parallel",
    "dev:gateway": "cross-env NODE_ENV=local nx serve gateway",
    "dev:auth": "cross-env NODE_ENV=local nx serve auth-service",
    "dev:notification": "cross-env NODE_ENV=local nx serve notification-service",
    "dev:upload": "cross-env NODE_ENV=local nx serve upload-service",
    "start:dev": "cross-env NODE_ENV=development nx run-many --target=serve --projects=gateway,auth-service --parallel",
    "start:staging": "cross-env NODE_ENV=staging nx run-many --target=serve --projects=gateway,auth-service --parallel",
    "start:production": "cross-env NODE_ENV=production nx run-many --target=serve --projects=gateway,auth-service --parallel",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:dev:infra": "docker-compose -f docker-compose.dev.yml up -d postgres redis rabbitmq",
    "docker:dev:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:dev:logs": "docker-compose -f docker-compose.dev.yml logs -f",
    "test:grpc": "node test-grpc.js",
    "db:generate": "nx run database:prisma:generate",
    "db:migrate": "nx run database:prisma:migrate",
    "db:migrate:deploy": "nx run database:prisma:migrate:deploy",
    "db:studio": "nx run database:prisma:studio",
    "db:seed": "nx run database:prisma:seed",
    "affected:build": "nx affected:build",
    "affected:test": "nx affected:test",
    "affected:lint": "nx affected:lint",
    "graph": "nx graph",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "clean": "nx reset",
    "generate": "nx generate",
    "proto:generate": "nx run common:proto-generate"
  },
  "prisma": {
    "seed": "node -r ./prisma/load-env.cjs ./node_modules/ts-node/dist/bin.js --project prisma/tsconfig.seed.json prisma/seed.ts"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.55.1",
    "@grpc/grpc-js": "^1.13.4",
    "@grpc/proto-loader": "^0.8.0",
    "@nx/eslint-plugin": "21.4.1",
    "@nx/jest": "21.4.1",
    "@nx/js": "21.4.1",
    "@nx/nest": "21.4.1",
    "@nx/webpack": "21.4.1",
    "@nx/workspace": "21.4.1",
    "cross-env": "^10.0.0",
    "eslint": "^9.34.0",
    "grpc-tools": "^1.13.0",
    "nx": "21.4.1",
    "prettier": "^3.6.2",
    "prisma": "6.15.0",
    "@prisma/client": "6.15.0",
    "ts-node": "^10.9.2",
    "ts-proto": "^2.7.7",
    "typescript": "5.9.2"
  }
}
