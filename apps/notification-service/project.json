{
  "name": "notification-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/notification-service/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "dependsOn": ["^build", "database:prisma:generate"],
      "options": {
        "outputPath": "apps/notification-service/dist",
        "main": "apps/notification-service/src/main.ts",
        "tsConfig": "apps/notification-service/tsconfig.json",
        "assets": []
      },
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["^build"],
      "options": {
        "buildTarget": "notification-service:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "notification-service:build:development",
          "watch": true
        },
        "production": {
          "buildTarget": "notification-service:build:production",
          "watch": false
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/notification-service/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/notification-service/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "tags": ["scope:notification", "type:app"]
}
